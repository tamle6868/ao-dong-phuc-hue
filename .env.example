# Public site URL — used for canonical links, OpenGraph, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://aodongphuchue.vn

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# `NEXT_PUBLIC_SUPABASE_URL`             — public REST endpoint
# `NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY` — new "publishable" key (sb_publishable_*)
#                                          aka legacy "anon" key. Safe in client.
# `SUPABASE_SERVICE_ROLE_KEY`            — new "secret" key (sb_secret_*) aka
#                                          legacy "service_role" key. Bypasses
#                                          RLS. SERVER ONLY — never expose.
# Leave any of these blank to fall back to mock data + log-only lead capture.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Analytics (optional — placeholders OK for dev)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
